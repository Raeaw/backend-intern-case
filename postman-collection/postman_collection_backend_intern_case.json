{
	"info": {
		"name": "Backend Intern Case - Laravel 12 REST API",
		"description": "Collection untuk testing REST API e-commerce sederhana (Laravel 12 + Sanctum).",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://127.0.0.1:8000/api",
			"type": "string"
		},
		{
			"key": "admin_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "user_token",
			"value": "",
			"type": "string"
		},
		{
			"key": "product_id",
			"value": "1",
			"type": "string"
		},
		{
			"key": "order_id",
			"value": "1",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login as Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const json = pm.response.json();",
									"    pm.collectionVariables.set('admin_token', json.data.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}"
						},
						"url": "{{base_url}}/login"
					}
				},
				{
					"name": "Login as User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const json = pm.response.json();",
									"    pm.collectionVariables.set('user_token', json.data.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password\"\n}"
						},
						"url": "{{base_url}}/login"
					}
				},
				{
					"name": "Login - Wrong Password (422)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"salah\"\n}"
						},
						"url": "{{base_url}}/login"
					}
				},
				{
					"name": "Logout",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" }
						],
						"url": "{{base_url}}/logout"
					}
				}
			]
		},
		{
			"name": "Products",
			"item": [
				{
					"name": "List Products (Public)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/products"
					}
				},
				{
					"name": "Get Product Detail (Public)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/products/{{product_id}}"
					}
				},
				{
					"name": "Get Product - Not Found (404)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/products/9999"
					}
				},
				{
					"name": "Create Product (Admin Only)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const json = pm.response.json();",
									"    pm.collectionVariables.set('product_id', json.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Kopi Susu\",\n  \"description\": \"Kopi susu gula aren\",\n  \"price\": 18000,\n  \"status\": \"active\"\n}"
						},
						"url": "{{base_url}}/products"
					}
				},
				{
					"name": "Create Product - Forbidden as User (403)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{user_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Produk Ilegal\",\n  \"price\": 5000,\n  \"status\": \"active\"\n}"
						},
						"url": "{{base_url}}/products"
					}
				},
				{
					"name": "Create Product - Validation Error (422)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"price\": -100,\n  \"status\": \"unknown\"\n}"
						},
						"url": "{{base_url}}/products"
					}
				},
				{
					"name": "Update Product (Admin Only)",
					"request": {
						"method": "PUT",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"price\": 25000\n}"
						},
						"url": "{{base_url}}/products/{{product_id}}"
					}
				},
				{
					"name": "Delete Product (Admin Only)",
					"request": {
						"method": "DELETE",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" }
						],
						"url": "{{base_url}}/products/{{product_id}}"
					}
				}
			]
		},
		{
			"name": "Orders",
			"item": [
				{
					"name": "Create Order (Public)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const json = pm.response.json();",
									"    pm.collectionVariables.set('order_id', json.data.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"customer_name\": \"Budi\",\n  \"customer_email\": \"budi@mail.com\",\n  \"items\": [\n    { \"product_id\": 1, \"qty\": 2 }\n  ]\n}"
						},
						"url": "{{base_url}}/orders"
					}
				},
				{
					"name": "Create Order - Inactive Product (422)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Accept", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"customer_name\": \"Budi\",\n  \"customer_email\": \"budi@mail.com\",\n  \"items\": [\n    { \"product_id\": 3, \"qty\": 1 }\n  ]\n}"
						},
						"url": "{{base_url}}/orders"
					}
				},
				{
					"name": "List Orders (Admin Only)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" }
						],
						"url": "{{base_url}}/orders"
					}
				},
				{
					"name": "List Orders - Unauthenticated (401)",
					"request": {
						"method": "GET",
						"header": [{ "key": "Accept", "value": "application/json" }],
						"url": "{{base_url}}/orders"
					}
				},
				{
					"name": "Get Order Detail (Admin Only)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Accept", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{admin_token}}" }
						],
						"url": "{{base_url}}/orders/{{order_id}}"
					}
				}
			]
		}
	]
}
